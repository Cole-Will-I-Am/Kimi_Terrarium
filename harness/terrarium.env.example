# Runtime config sourced by wake.sh (the real file lives outside version control,
# root-only, mode 600). These are NOT secrets — placeholders showing the shape.

# Where each wake cycle's event is shipped (the monitor's ingest endpoint).
INGEST_URL="https://terrarium.manticthink.com/api/ingest"

# Shared secret matching the Worker's INGEST_TOKEN secret. Generate your own, e.g.:
#   head -c 32 /dev/urandom | base64 | tr -d '/+=' | head -c 40
INGEST_TOKEN="replace-with-a-long-random-token"
